      "name": "GoRest CRUD Tests with Dynamic data",
      "item": [
        {
          "name": "Adding new user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var ran=Math.random().toString(36).substring(2);\r",
                  "var name=\"Manish\"+ran;\r",
                  "var email = \"manish\" + ran + \"@gmail.com\";\r",
                  "console.log(ran);\r",
                  "\r",
                  "pm.collectionVariables.set(\"gorestUrl\", \"https://gorest.co.in/public/v2/users\");\r",
                  "pm.environment.set(\"name_vr\", name);\r",
                  "pm.environment.set(\"email_vr\", email);\r",
                  "pm.environment.set(\"authToken\", \"0078e7baba468a32cbd4ef5dfa6103fb5ec5cc5bde2a6434190d0c153da4a472\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"New user created successfully\",()=>{\r",
                  "    pm.expect(pm.response.code).to.eql(201);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "var jdata=pm.response.json();\r",
                  "console.log(jdata);\r",
                  "\r",
                  "pm.environment.set(\"user_id\", jdata.id);"
                ],
